<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>С 8 Марта! ❤️ Мама и Бабушка</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Arial', sans-serif;
            background: linear-gradient(145deg, #f9e3e3 0%, #fad0d0 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 15px;
            position: relative;
            overflow-x: hidden;
        }

        .card {
            max-width: 400px;
            width: 100%;
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 50px 50px 30px 30px;
            box-shadow: 0 25px 40px rgba(0,0,0,0.2), 0 0 0 2px #fff8 inset;
            overflow: hidden;
            padding: 25px 20px 35px 20px;
            text-align: center;
            border: 1px solid #ffb7b7;
            position: relative;
            z-index: 2;
        }

        h1 {
            font-size: 2.2rem;
            color: #b3436b;
            text-shadow: 2px 2px 0 #fff2e6;
            margin-bottom: 5px;
            font-weight: 600;
            letter-spacing: 1px;
        }

        .subtitle {
            font-size: 1.3rem;
            color: #b85c7a;
            margin-bottom: 25px;
            font-style: italic;
            background: #ffe9f0b3;
            display: inline-block;
            padding: 8px 25px;
            border-radius: 50px;
            backdrop-filter: blur(5px);
            border: 1px solid white;
        }

        /* Контейнер фото */
        .photo-gallery {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            margin: 25px 0 20px 0;
        }

        .photo-item {
            flex: 1 1 130px;
            min-width: 120px;
            max-width: 160px;
        }

        .photo-frame {
            background: white;
            padding: 8px 8px 15px 8px;
            border-radius: 35px 35px 25px 25px;
            box-shadow: 0 10px 20px rgba(150, 40, 60, 0.25);
            transform: rotate(-1deg);
            transition: 0.3s;
            border: 2px solid #ffd9df;
        }

        .photo-item:last-child .photo-frame {
            transform: rotate(2deg);
        }

        .photo-frame img {
            width: 100%;
            height: auto;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border-radius: 25px 25px 15px 15px;
            display: block;
            background: #f7cfd8;
        }

        /* Заглушки для фото */
        .photo-frame img {
            content: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="%23ffc1cc"><circle cx="50" cy="45" r="25" fill="%23ffb3b3"/><circle cx="35" cy="40" r="4" fill="white"/><circle cx="65" cy="40" r="4" fill="white"/><circle cx="38" cy="38" r="2" fill="black"/><circle cx="62" cy="38" r="2" fill="black"/><path d="M40 60 Q50 75, 60 60" stroke="%23b3436b" stroke-width="4" fill="none" stroke-linecap="round"/><rect x="20" y="70" width="60" height="15" fill="%23d46b7a" rx="7"/></svg>');
        }

        .photo-name {
            margin-top: 10px;
            font-weight: 600;
            font-size: 1.2rem;
            color: #a13258;
            background: #ffe2ebcc;
            padding: 5px 10px;
            border-radius: 30px;
            backdrop-filter: blur(2px);
            border: 1px solid white;
        }

        .poem {
            background: #fff0f5ee;
            border-radius: 70px 20px 70px 20px;
            padding: 25px 20px;
            margin: 30px 0 20px 0;
            border: 2px dashed #ff99bb;
            color: #4e2d3b;
            font-size: 1.1rem;
            line-height: 1.7;
            box-shadow: 0 5px 0 #ffb6c1;
        }

        .poem p {
            margin: 10px 0;
        }

        .poem i {
            color: #b3436b;
            font-size: 1.3rem;
        }

        .footer-hearts {
            font-size: 2.5rem;
            letter-spacing: 10px;
            color: #e46b8a;
            margin: 15px 0 10px 0;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.1); opacity: 1; text-shadow: 0 0 10px #ff9ebb; }
            100% { transform: scale(1); opacity: 0.8; }
        }

        .btn-music {
            background: #fff0f5;
            border: 2px solid #ff87a2;
            color: #b3436b;
            font-size: 1.3rem;
            padding: 12px 20px;
            border-radius: 60px;
            width: fit-content;
            margin: 10px auto 0;
            box-shadow: 0 5px 0 #e48e9e;
            transition: 0.1s ease;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            cursor: pointer;
        }

        .btn-music:active {
            transform: translateY(5px);
            box-shadow: none;
        }

        .date {
            margin-top: 30px;
            color: #9b5971;
            font-size: 1rem;
        }

        /* Контейнер для летающих сердечек */
        #hearts-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 9999;
            overflow: hidden;
        }

        .heart {
            position: absolute;
            font-size: 24px;
            animation: floatUp 4s ease-out forwards;
            filter: drop-shadow(0 0 5px rgba(255, 100, 150, 0.5));
        }

        @keyframes floatUp {
            0% {
                transform: translateY(100vh) scale(0.5);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            100% {
                transform: translateY(-20vh) scale(1.2);
                opacity: 0;
            }
        }
    </style>
</head>
<body>
    <div id="hearts-container"></div>
    
    <div class="card">
        <h1>🌸 С 8 Марта! 🌸</h1>
        <div class="subtitle">Мамочка и Бабушка</div>

        <!-- Фото рамки -->
        <div class="photo-gallery">
            <div class="photo-item">
                <div class="photo-frame">
                    <img src="https://via.placeholder.com/200/f9c7d3/ffffff?text=❤️+Мама" alt="Мама">
                </div>
                <div class="photo-name">Мамуля</div>
            </div>
            <div class="photo-item">
                <div class="photo-frame">
                    <img src="https://via.placeholder.com/200/f9b8c3/ffffff?text=🌷+Бабушка" alt="Бабушка">
                </div>
                <div class="photo-name">Бабушка</div>
            </div>
        </div>

        <!-- Тёплые стихи -->
        <div class="poem">
            <p><i>❤️</i></p>
            <p>Мамочка, милая, нежная самая,<br>
            Бабушка, добрая, золотая,</p>
            <p>В этот весенний, цветущий денёк<br>
            Пусть счастья лучистый зажгись огонёк!</p>
            <p>Пусть улыбаются ваши глаза,<br>
            И не скатывается ни одна слеза.<br>
            Здоровья, тепла, и цветов, и добра,<br>
            Вы — наши лучшие, вы — наши сердца!</p>
            <p><i>🌷</i></p>
        </div>

        <!-- Сердечки анимация -->
        <div class="footer-hearts">
            ❤️ 💛 💚
        </div>

        <!-- Кнопка с сюрпризом -->
        <button class="btn-music" id="surpriseBtn">
            <span>🎵</span> Сюрприз <span>🎶</span>
        </button>

        <div class="date" id="currentDate"></div>
    </div>

    <script>
        // Вставляем дату
        const dateElement = document.getElementById('currentDate');
        const today = new Date();
        const options = { year: 'numeric', month: 'long', day: 'numeric' };
        dateElement.textContent = `С любовью, ${today.toLocaleDateString('ru-RU', options)}`;

        // Функция для создания летающих сердечек
        function createFloatingHearts() {
            const container = document.getElementById('hearts-container');
            const colors = ['❤️', '🧡', '💛', '💚', '💙', '💜', '🩷', '💖', '💗', '💓'];
            const heartCount = 40; // Количество сердечек
            
            for (let i = 0; i < heartCount; i++) {
                setTimeout(() => {
                    const heart = document.createElement('div');
                    heart.className = 'heart';
                    
                    // Случайный символ сердечка
                    const randomHeart = colors[Math.floor(Math.random() * colors.length)];
                    heart.textContent = randomHeart;
                    
                    // Случайный размер
                    const size = Math.floor(Math.random() * 30) + 20;
                    heart.style.fontSize = size + 'px';
                    
                    // Случайная позиция по горизонтали
                    const left = Math.random() * 100;
                    heart.style.left = left + '%';
                    
                    // Случайная задержка анимации
                    const delay = Math.random() * 2;
                    heart.style.animationDelay = delay + 's';
                    
                    // Случайная длительность анимации
                    const duration = Math.random() * 2 + 3;
                    heart.style.animationDuration = duration + 's';
                    
                    container.appendChild(heart);
                    
                    // Удаляем сердечко после окончания анимации
                    setTimeout(() => {
                        heart.remove();
                    }, duration * 1000 + delay * 1000);
                }, i * 100); // Запускаем с небольшой задержкой для эффекта "фонтана"
            }
        }

        // Сюрприз при клике
        const btn = document.getElementById('surpriseBtn');
        btn.addEventListener('click', function() {
            // Запускаем сердечки
            createFloatingHearts();
            
            // Показываем сообщение
            alert('🌸 С праздником, родные! Пусть ваши сердца всегда наполняются радостью! 🌸');
            
            // Вибрация на телефоне (если поддерживается)
            if (navigator.vibrate) {
                navigator.vibrate([200, 100, 200]);
            }
        });

        // Добавляем автоматическое появление нескольких сердечек при загрузке
        window.addEventListener('load', function() {
            setTimeout(() => {
                createFloatingHearts(); // Небольшой сюрприз сразу
            }, 500);
        });
    </script>
</body>
</html>
